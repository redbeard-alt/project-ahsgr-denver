# AHSGR executive-assistant brief runtime.
# Copy to .env and fill in only after Phase 2b credentials/webhook setup.

OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1:8b

# Discord delivery target. Phase 2b must use a private preview webhook first.
DISCORD_WEBHOOK_URL=

# Google OAuth, read-only for Phase 2a/2b context pulls.
# Alternative: clients/ahsgr-north-denver/google_credentials.json (gitignored).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_TOKEN_URI=https://oauth2.googleapis.com/token
